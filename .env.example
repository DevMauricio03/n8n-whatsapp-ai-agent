# Copia este archivo como .env y reemplaza todos los valores CHANGE_ME.
# Usa versiones o digests que hayas validado antes de desplegar.

TZ=America/Mexico_City

# Dominios públicos
N8N_DOMAIN=n8n.example.com
CHATWOOT_DOMAIN=chat.example.com
LETSENCRYPT_EMAIL=admin@example.com

# Imágenes. Evita "latest" en producción.
POSTGRES_IMAGE=pgvector/pgvector:pg15
REDIS_IMAGE=redis:7-alpine
CADDY_IMAGE=caddy:2-alpine
N8N_IMAGE=docker.n8n.io/n8nio/n8n:1
CHATWOOT_IMAGE=chatwoot/chatwoot:v4.4.0

# Base de datos compartida por infraestructura.
# El script de inicio crea: n8n, chatwoot y agent.
POSTGRES_USER=platform
POSTGRES_PASSWORD=CHANGE_ME_USE_A_LONG_RANDOM_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_USE_A_LONG_RANDOM_PASSWORD

# n8n
N8N_ENCRYPTION_KEY=CHANGE_ME_USE_AT_LEAST_32_RANDOM_CHARACTERS

# Chatwoot
CHATWOOT_SECRET_KEY_BASE=CHANGE_ME_USE_A_LONG_RANDOM_SECRET
CHATWOOT_ENABLE_ACCOUNT_SIGNUP=false

# Variables disponibles para nodos del workflow.
# También pueden administrarse mediante credenciales de n8n.
WHATSAPP_GRAPH_API_VERSION=v22.0
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME
GOOGLE_DRIVE_SOURCE_FILE_ID=CHANGE_ME
PRICE_IMAGE_PACKAGE_1_URL=https://example.com/package-1.png
PRICE_IMAGE_PACKAGE_2_URL=https://example.com/package-2.png
PRICE_IMAGE_ANALYSIS_URL=https://example.com/analysis.png
