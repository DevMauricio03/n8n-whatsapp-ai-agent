services:
  prepare:
    image: ${CHATWOOT_IMAGE}
    container_name: platform-chatwoot-prepare
    restart: "no"
    command: ["bundle", "exec", "rails", "db:chatwoot_prepare"]
    environment: &chatwoot_environment
      RAILS_ENV: production
      NODE_ENV: production
      INSTALLATION_ENV: docker
      FRONTEND_URL: https://${CHATWOOT_DOMAIN}
      SECRET_KEY_BASE: ${CHATWOOT_SECRET_KEY_BASE}
      ENABLE_ACCOUNT_SIGNUP: ${CHATWOOT_ENABLE_ACCOUNT_SIGNUP}
      POSTGRES_HOST: platform-postgres
      POSTGRES_PORT: 5432
      POSTGRES_DATABASE: chatwoot
      POSTGRES_USERNAME: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      REDIS_URL: redis://:${REDIS_PASSWORD}@platform-redis:6379
    networks:
      - platform_net

  rails:
    image: ${CHATWOOT_IMAGE}
    container_name: platform-chatwoot-rails
    restart: unless-stopped
    command: ["bundle", "exec", "rails", "s", "-p", "3000", "-b", "0.0.0.0"]
    environment: *chatwoot_environment
    depends_on:
      prepare:
        condition: service_completed_successfully
    volumes:
      - storage_data:/app/storage
    networks:
      - platform_net

  sidekiq:
    image: ${CHATWOOT_IMAGE}
    container_name: platform-chatwoot-sidekiq
    restart: unless-stopped
    command: ["bundle", "exec", "sidekiq", "-C", "config/sidekiq.yml"]
    environment: *chatwoot_environment
    depends_on:
      prepare:
        condition: service_completed_successfully
    volumes:
      - storage_data:/app/storage
    networks:
      - platform_net

volumes:
  storage_data:

networks:
  platform_net:
    external: true
    name: platform_net
